# ----- DO NOT MODIFY -----

export COURSE := OS2022
URL := 'http://jyywiki.cn/static/submit-os2022.sh'

submit:
	@cd $(dir $(abspath $(lastword $(MAKEFILE_LIST)))) && \
	  curl -sSLf '$(URL)' && \
	  curl -sSLf '$(URL)' | bash

# NOTE: the upstream workbench 'git' target auto-commits after every build
# (used by NJU's online judge to snapshot submissions). In this standalone
# repo that would pollute history with "uname -a / uptime" commits, so it is
# a no-op here. Real commits are made explicitly by the author.
git:
	@true
